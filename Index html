        function enterApp() {
            const user = document.getElementById('username').value || "Guest";
            document.getElementById('login-page').style.opacity = "0";
            setTimeout(() => {
                document.getElementById('login-page').classList.add('hidden');
                document.getElementById('app-page').style.display = 'flex';
                document.getElementById('welcome-msg').innerText = `المستخدم المتصل: ${user}`;
                setTimeout(() => document.getElementById('app-page').style.opacity = "1", 50);
                loadGrid();
            }, 600);
        }

        function loadGrid() {
            const grid = document.getElementById('iconGrid');
            grid.innerHTML = '';
            wilayas.forEach(w => {
                const icon = document.createElement('div');
                icon.className = 'wilaya-icon';
                icon.innerHTML = `<span class="num">${w.id}</span><span style="font-size:0.75rem; font-weight:bold;">${w.n}</span>`;
                icon.onclick = () => openModal(w);
                grid.appendChild(icon);
            });
        }

        function openModal(w) {
            document.getElementById('m-name').innerText = w.n;
            document.getElementById('m-id').innerText = `ولاية رقم: ${w.id}`;
            document.getElementById('m-famous').innerText = w.f;
            document.getElementById('m-anem').innerText = w.p;
            document.getElementById('infoModal').style.display = 'flex';
        }

        function closeModal() { document.getElementById('infoModal').style.display = 'none'; }
    </script>
</body>
</html>
