<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>V58 - دليل ولايات الجزائر الشامل</title>
    <style>
        :root {
            --primary: #008751;
            --accent: #d4af37;
            --bg-dark: #020617;
            --card-glass: rgba(255, 255, 255, 0.05);
        }

        body, html {
            margin: 0; padding: 0; height: 100%;
            font-family: 'Segoe UI', Arial, sans-serif;
            background-color: var(--bg-dark);
            color: white; overflow: hidden;
        }

        /* الخلفية ثلاثية الأبعاد */
        .bg-3d-container {
            position: fixed; width: 100vw; height: 100vh;
            perspective: 1000px; z-index: -1;
        }

        .animated-grid {
            width: 200%; height: 200%;
            background-image: 
                linear-gradient(rgba(0, 135, 81, 0.1) 1px, transparent 1px),
                linear-gradient(90deg, rgba(0, 135, 81, 0.1) 1px, transparent 1px);
            background-size: 50px 50px;
            transform: rotateX(60deg) translateY(-20%);
            animation: gridMove 20s linear infinite;
        }

        @keyframes gridMove {
            from { transform: rotateX(60deg) translateY(0); }
            to { transform: rotateX(60deg) translateY(50px); }
        }

        /* واجهة الدخول */
        #login-page {
            display: flex; flex-direction: column; align-items: center;
            justify-content: center; height: 100vh; transition: 0.8s ease;
        }

        .login-card {
            background: var(--card-glass); backdrop-filter: blur(20px);
            padding: 40px; border-radius: 30px; border: 1px solid rgba(255,255,255,0.1);
            width: 320px; text-align: center;
        }

        .algeria-logo {
            width: 100px; height: 100px;
            background: url('https://wikimedia.org') center/contain no-repeat;
            margin: 0 auto 20px; filter: drop-shadow(0 0 10px var(--primary));
            animation: float 3s infinite ease-in-out;
        }

        @keyframes float { 0%, 100% { transform: translateY(0); } 50% { transform: translateY(-10px); } }

        .login-btn {
            width: 100%; padding: 12px; background: var(--primary);
            border: none; border-radius: 10px; color: white;
            font-weight: bold; cursor: pointer; margin-top: 15px;
        }

        /* واجهة الولايات */
        #app-page {
            display: none; height: 100vh; flex-direction: column;
            overflow-y: auto; padding: 20px; opacity: 0; transition: 1s;
        }

        .icon-grid {
            display: grid; grid-template-columns: repeat(auto-fill, minmax(95px, 1fr));
            gap: 15px; padding-bottom: 50px; width: 100%; max-width: 1100px; margin: 0 auto;
        }

        .wilaya-icon {
            background: var(--card-glass); aspect-ratio: 1;
            border-radius: 15px; display: flex; flex-direction: column;
            align-items: center; justify-content: center; cursor: pointer;
            border: 1px solid rgba(255,255,255,0.05); transition: 0.3s;
            text-align: center; padding: 5px;
        }

        .wilaya-icon:hover { background: var(--primary); transform: translateY(-5px); }
        .wilaya-icon .num { font-size: 1.3rem; font-weight: 900; color: var(--accent); }

        /* نافذة المعلومات */
        .modal {
            position: fixed; inset: 0; background: rgba(0,0,0,0.9);
            display: none; align-items: center; justify-content: center; z-index: 1000;
        }

        .modal-content {
            background: #1e293b; padding: 30px; border-radius: 20px;
            width: 85%; max-width: 380px; text-align: center;
            border-right: 8px solid var(--primary);
        }

        .anem-box {
            background: rgba(0, 135, 81, 0.1); padding: 15px;
            border-radius: 15px; margin-top: 20px; border: 1px dashed var(--primary);
        }

        #m-anem { 
            display: block; direction: ltr; /* من اليسار إلى اليمين */
            font-family: 'Courier New', monospace; font-size: 1.4rem;
            font-weight: bold; color: var(--accent); margin-top: 10px; letter-spacing: 2px;
        }

        .hidden { display: none !important; }
    </style>
</head>
<body>

    <div class="bg-3d-container">
        <div class="animated-grid"></div>
    </div>

    <!-- شاشة الدخول -->
    <div id="login-page">
        <div class="login-card">
            <div class="algeria-logo"></div>
            <h1 style="color: var(--accent); margin:0;">V58</h1>
            <p style="color: #94a3b8; font-size: 0.8rem; margin-bottom: 20px;">الدليل الرقمي لولايات الوطن</p>
            <input type="text" placeholder="اسم المستخدم" id="username" style="width:100%; padding:10px; margin-bottom:10px; background:rgba(0,0,0,0.3); border:1px solid #334155; color:white; border-radius:8px; text-align:center;">
            <button class="login-btn" onclick="enterApp()">دخول</button>
        </div>
    </div>

    <!-- شاشة التطبيق -->
    <div id="app-page">
        <div style="text-align: center; margin-bottom: 30px;">
            <h2 style="color: var(--accent);">قائمة الـ 58 ولاية</h2>
            <p id="welcome-msg" style="color: var(--primary);"></p>
        </div>
        <div class="icon-grid" id="iconGrid"></div>
    </div>

    <!-- نافذة المعلومات -->
    <div class="modal" id="infoModal">
        <div class="modal-content">
            <h2 id="m-name" style="color: var(--accent); margin: 0;"></h2>
            <p id="m-id" style="font-weight: bold; color: #94a3b8; font-family: Arial;"></p>
            
            <div style="text-align: right; margin-top: 20px;">
                <label style="color: var(--primary); font-size: 0.8rem;">نشتهر بـ:</label>
                <p id="m-famous" style="font-size: 0.95rem; margin: 5px 0;"></p>
            </div>

            <div class="anem-box">
                <label style="color: var(--accent); font-size: 0.85rem; display: block; margin-bottom: 5px;">📞 وكالة التشغيل (ANEM):</label>
                <span id="m-anem"></span>
            </div>

            <button onclick="closeModal()" style="margin-top:25px; width: 100%; padding: 12px; border-radius: 10px; border:none; background: #334155; color: white; cursor: pointer;">إغلاق</button>
        </div>
    </div>

